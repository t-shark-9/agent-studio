{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Agent Studio",
  "version": "0.1.0",
  "identifier": "de.tjark.agentstudio",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:8081",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Agent Studio",
        "width": 1440,
        "height": 920,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "../public/favicon-32.png",
      "../public/favicon-512.png",
      "../public/favicon.ico"
    ]
  }
}
